# AI Urban Traffic Digital Twin - Environment Configuration

# Backend
BACKEND_PORT=8000
APP_NAME=AI Urban Traffic Digital Twin
DEBUG=true

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/ai_traffic_twin
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ai_traffic_twin
DB_USER=postgres
DB_PASSWORD=postgres

# AI Models
YOLO_MODEL_PATH=./ai_models/yolov8.pt
DEEPSORT_MODEL_PATH=./ai_models/deepsort/
XGBOOST_MODEL_PATH=./ai_models/xgboost/
LSTM_MODEL_PATH=./ai_models/lstm/

# Redis (optional, for caching)
REDIS_URL=redis://localhost:6379/0
